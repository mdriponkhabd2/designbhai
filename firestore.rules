
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Simplified admin check to avoid recursive dependency errors
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list, write: if isAdmin();
      allow create: if isSignedIn();
    }

    match /website_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true; // Allow anyone to place an order
      allow read, update, delete: if isAdmin();
    }

    match /wallets/{uid} {
      allow get: if isAdmin();
      allow write: if isAdmin();
    }

    match /wallet_requests/{requestId} {
      allow create: if true; // Allow guests to request (if ever needed)
      allow read, update, delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
