
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /website_config/{configId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /portfolioItems/{portfolioItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      // Allow users to list their own orders or admins to see everything
      // The query must be filtered by userId for non-admins
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
