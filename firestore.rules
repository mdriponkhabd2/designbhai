
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /portfolioItems/{portfolioItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /aboutUs/{aboutUsId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactInfo/{contactInfoId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /websiteSettings/{settingId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow get, list, update, delete: if isAdmin();
    }
  }
}
