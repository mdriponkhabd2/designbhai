
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{adminUid} {
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list, write: if isAdmin();
      allow create: if isSignedIn();
    }

    match /website_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      // Use 'read' which covers both 'get' and 'list'
      // Ensure the query includes a filter for 'userId' matching the auth UID
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /wallets/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /wallet_requests/{requestId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
