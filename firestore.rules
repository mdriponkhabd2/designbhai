rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /admin_roles/{adminUid} {
      // Allow users to read their own role doc to verify status
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      allow list: if isAdmin();
      // Allow creation during bootstrap/login phase
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /portfolioItems/{portfolioItemId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /aboutUs/{aboutUsId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactInfo/{contactInfoId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /websiteSettings/{settingId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactMessages/{messageId} {
      // Public can CREATE messages, but only Admins can READ/LIST them
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}