
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Check if the user's UID exists in the admin_roles collection
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    match /admin_roles/{adminUid} {
      // Users can see their own admin status
      allow get: if isSignedIn() && request.auth.uid == adminUid;
      // Listing admin roles is only for admins
      allow list: if isAdmin();
      // Admin creation should be restricted, but for this app's logic we allow it during setup
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /website_config/{configId} {
      // Everyone can read the website configuration (services, pricing, about, etc.)
      allow get: if true;
      // Only admins can update the website settings
      allow write: if isAdmin();
    }

    match /portfolioItems/{portfolioItemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contactMessages/{messageId} {
      // Public can send messages
      allow create: if true;
      // Only admin can read or manage messages
      allow read, write: if isAdmin();
    }

    match /orders/{orderId} {
      // Public can place orders
      allow create: if true;
      
      // Get: Admin can see any order, users can only see their own
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // List: Admin can list all, users can only list their own (requires query filter)
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && (resource == null || resource.data.userId == request.auth.uid));
      
      // Only admin can update (status) or delete
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      // Public can see products
      allow read: if true;
      // Only admin can manage products
      allow write: if isAdmin();
    }
  }
}
