
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a registered customer.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a service order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "packageName": { "type": "string" },
        "packagePrice": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["bKash", "Nagad"] },
        "trxId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "phoneNumber", "packageName", "paymentMethod", "trxId", "status", "userId"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Registered user profiles."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Collection for customer orders."
    },
    "/admin_roles/{uid}": {
      "schema": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["admin"] }
        }
      },
      "description": "Stores administrative privileges."
    },
    "/website_config/main": {
      "schema": { "type": "object" },
      "description": "Global website configuration data."
    }
  }
}
