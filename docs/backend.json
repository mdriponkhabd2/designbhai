
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a service order placed by a customer.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who placed the order. Used for security rule filtering."
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the customer."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Primary contact number."
        },
        "whatsAppNumber": {
          "type": "string",
          "description": "WhatsApp number for communication."
        },
        "packageName": {
          "type": "string",
          "description": "Name of the package ordered."
        },
        "packagePrice": {
          "type": "string",
          "description": "Price of the package at the time of order."
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment gateway used (bKash/Nagad).",
          "enum": ["bKash", "Nagad"]
        },
        "trxId": {
          "type": "string",
          "description": "Transaction ID provided by the user."
        },
        "status": {
          "type": "string",
          "description": "Current status of the order.",
          "enum": ["pending", "processing", "completed", "cancelled"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the order was placed.",
          "format": "date-time"
        }
      },
      "required": [
        "fullName",
        "phoneNumber",
        "packageName",
        "paymentMethod",
        "trxId",
        "status"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Collection for customer orders. Users can only list their own orders."
    },
    "/admin_roles/{uid}": {
      "schema": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["admin"] }
        }
      },
      "description": "Stores administrative privileges."
    },
    "/website_config/main": {
      "schema": { "type": "object" },
      "description": "Global website configuration data."
    }
  }
}
