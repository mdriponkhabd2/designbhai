
{
  "entities": {
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a service order placed by a customer.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Order."
        },
        "fullName": {
          "type": "string",
          "description": "Full name of the customer."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Primary contact number."
        },
        "whatsAppNumber": {
          "type": "string",
          "description": "WhatsApp number for communication."
        },
        "packageName": {
          "type": "string",
          "description": "Name of the package ordered."
        },
        "packagePrice": {
          "type": "string",
          "description": "Price of the package at the time of order."
        },
        "paymentMethod": {
          "type": "string",
          "description": "Payment gateway used (bKash/Nagad).",
          "enum": ["bKash", "Nagad"]
        },
        "trxId": {
          "type": "string",
          "description": "Transaction ID provided by the user."
        },
        "status": {
          "type": "string",
          "description": "Current status of the order.",
          "enum": ["pending", "processing", "completed", "cancelled"]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the order was placed.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "fullName",
        "phoneNumber",
        "packageName",
        "paymentMethod",
        "trxId",
        "status",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Collection for customer orders. Public can create, Admin can read/update.",
          "params": [
            {
              "name": "orderId",
              "description": "The unique ID for the order."
            }
          ]
        }
      }
    ]
  }
}
