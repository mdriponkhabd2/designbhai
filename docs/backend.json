
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Represents a service order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "packageName": { "type": "string" },
        "packagePrice": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["bKash", "Nagad"] },
        "trxId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "phoneNumber", "packageName", "paymentMethod", "trxId", "status", "userId"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User's virtual balance and transaction history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WalletRequest": {
      "title": "Wallet Request",
      "description": "Request to add money to wallet.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "trxId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Collection for customer orders."
    },
    "/wallets/{uid}": {
      "schema": { "$ref": "#/backend/entities/Wallet" },
      "description": "Stores user virtual balance."
    },
    "/wallet_requests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/WalletRequest" },
      "description": "Money add requests."
    },
    "/admin_roles/{uid}": {
      "schema": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["admin"] }
        }
      },
      "description": "Stores administrative privileges."
    },
    "/website_config/main": {
      "schema": { "type": "object" },
      "description": "Global website configuration data."
    }
  }
}
